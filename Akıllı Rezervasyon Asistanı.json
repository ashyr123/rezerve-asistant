    {
      "parameters": {
        "jsCode": "const items = $('Uygunluk Kontrol Et').all();\nconst rezervasyon = $('Geçerli Rezervasyon mu?').item.json.output;\n\n// Aynı tarih + saat + tercih kombinasyonunu say\nconst ayniSlot = items.filter(i => {\n  if (!i.json || !i.json['Tarih']) return false;\n  \n  const tarihEsit = String(i.json['Tarih']).trim() === String(rezervasyon.date).trim();\n  const saatEsit  = String(i.json['Saat']).trim()  === String(rezervasyon.time).trim();\n  const tercihEsit = String(i.json['Tercih'] || i.json['preference'] || '')\n                      .toLowerCase().trim() === \n                     String(rezervasyon.preference || '').toLowerCase().trim();\n  \n  return tarihEsit && saatEsit && tercihEsit;\n});\n\n// Masa kapasiteleri\nconst KAPASITE = {\n  'cam kenarı': 2,\n  'iç mekan':   5,\n  'teras':       3,\n  'orta':       4\n};\n\nconst tercih = String(rezervasyon.preference || '').toLowerCase().trim();\nconst maxKapasite = KAPASITE[tercih] ?? 3;\nconst musait = ayniSlot.length < maxKapasite;\n\nreturn [{ json: {\n  reservation_count: ayniSlot.length,\n  max_kapasite: maxKapasite,\n  is_available: musait,\n  tercih: tercih\n}}];"
      },
