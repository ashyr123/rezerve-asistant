    {
      "parameters": {
        "jsCode": "const items = $('Uygunluk Kontrol Et').all();\nconst rezervasyon = $('Geçerli Rezervasyon mu?').item.json.output;\nconst telegramId = $('Telegram Mesajı Al').item.json.message.chat.id;\n\n// Aynı kişi aynı slota zaten kayıtlı mı?\nconst mukerrer = items.some(i => {\n  return (\n    String(i.json['TelegramID']) === String(telegramId) &&\n    String(i.json['Tarih']).trim() === String(rezervasyon.date).trim() &&\n    String(i.json['Saat']).trim() === String(rezervasyon.time).trim()\n  );\n});\n\nreturn [{ json: { mukerrer } }];"
      },
